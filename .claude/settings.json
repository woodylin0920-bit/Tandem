{
  "statusLine": {
    "type": "command",
    "command": "bash scripts/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Bash(osascript:*)",
      "Bash(say:*)",
      "Bash(bash scripts/archive-prompts.sh:*)",
      "Bash(bash scripts/memory.sh:*)",
      "Bash(bash scripts/notify-blocked.sh:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-briefing.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/notify-blocked.sh"
          }
        ]
      }
    ]
  }
}
